# Supabase (public — used by browser client)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-only — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional overrides
DAILY_EMAIL_LIMIT=500
API_RATE_LIMIT_PER_MINUTE=60
MAX_MAILBOXES_PER_USER=100
MAX_MAILBOX_CREATIONS_PER_HOUR=20
MAILBOX_TOKEN_EXPIRY_HOURS=0
ENABLE_MOCK_DNS_VERIFICATION=false
INBOUND_WEBHOOK_SECRET=change-me-to-a-long-random-secret
